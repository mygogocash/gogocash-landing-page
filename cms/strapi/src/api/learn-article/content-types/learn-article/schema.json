{
  "kind": "collectionType",
  "collectionName": "learn_articles",
  "info": {
    "singularName": "learn-article",
    "pluralName": "learn-articles",
    "displayName": "Learn Article",
    "description": "Published GoGoCash Learn articles consumed by the static landing build."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120
    },
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 180
    },
    "hubDesc": {
      "type": "text",
      "required": true,
      "maxLength": 180
    },
    "content": {
      "type": "richtext",
      "required": true
    }
  }
}
