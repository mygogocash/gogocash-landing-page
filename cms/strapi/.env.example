# Local Strapi CMS for GoGoCash Learn content.
# Copy to cms/strapi/.env and replace every generated value before sharing a real CMS.

HOST=0.0.0.0
PORT=1337
APP_KEYS=replace-with-key-1,replace-with-key-2,replace-with-key-3,replace-with-key-4
API_TOKEN_SALT=replace-with-api-token-salt
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-with-transfer-token-salt
JWT_SECRET=replace-with-jwt-secret
ENCRYPTION_KEY=replace-with-admin-encryption-key

# Default local npm run cms:dev uses SQLite for quickest setup.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Docker Compose profile overrides these for Postgres.
# DATABASE_CLIENT=postgres
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_NAME=gogocash_cms
# DATABASE_USERNAME=gogocash
# DATABASE_PASSWORD=gogocash_dev_password
# DATABASE_SSL=false
