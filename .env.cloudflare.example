# Copy to .env.cloudflare (gitignored) and fill CLOUDFLARE_API_TOKEN.
# Token: Cloudflare Dashboard → My Profile → API Tokens → Create Token
#         → "Edit zone DNS" scoped to zone gogocash.co only.
#
# Then run: npm run dns:cloudflare-firebase-apex
# Optional dry run: DRY_RUN=1 npm run dns:cloudflare-firebase-apex

CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
# Required when multiple accounts are linked to your token or Wrangler login:
CLOUDFLARE_ACCOUNT_ID=187ab61ed9dbc6e616cb23e6b95aa8f1
