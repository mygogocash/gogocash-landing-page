# Copy to .env.cloudflare (gitignored) only for local Cloudflare deploy/dry-run work.
# GitHub Actions should use repository secrets/variables instead.

# Cloudflare Dashboard -> My Profile -> API Tokens -> Create Token.
# Required scopes for deploy:
# - Account -> Workers Scripts -> Edit
# - Account -> Workers Tail -> Read (optional, for logs)
# - Zone -> Workers Routes -> Edit
# - Zone -> DNS -> Edit (only if you manage DNS records manually with Wrangler/dashboard)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Optional, useful for manual DNS verification/cutover notes.
CLOUDFLARE_ZONE_ID=your_zone_id_here
