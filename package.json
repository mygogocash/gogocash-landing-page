{
  "name": "gogocash-landing",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mygogocash/landing-page.git"
  },
  "type": "module",
  "scripts": {
    "setup": "npm install --force",
    "start:dev": "bash scripts/start-dev.sh",
    "local": "npm install --force && npm run dev",
    "clean": "rm -rf .next",
    "dev:local": "bash scripts/dev-local.sh",
    "dev:docker": "docker compose up --build",
    "dev": "npm run typecheck && npm exec -- next dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "npm run clean && npm run dev",
    "dev:webpack": "npm run typecheck && npm exec -- next dev --webpack",
    "build": "npm run typecheck && npm exec -- next build",
    "postbuild": "node --import tsx scripts/postprocess-static-export.ts",
    "build:webpack": "npm run typecheck && npm exec -- next build --webpack",
    "analyze": "cross-env ANALYZE=true npm run build:webpack",
    "analyze:turbopack": "npm run typecheck && npm exec -- next experimental-analyze",
    "build:clean": "npm run clean && npm run build",
    "deploy:cloudflare": "npm run build && npm exec -- wrangler deploy --config wrangler.production.jsonc",
    "deploy:firebase": "npm run build && node scripts/deploy-firebase-hosting.mjs",
    "deploy:firebase:full": "npm run deploy:firebase",
    "start": "npm exec -- next start",
    "lint": "node --import ./scripts/register-eslint-typescript-compat.mjs ./node_modules/eslint/bin/eslint.js . --ignore-pattern node_modules --ignore-pattern .next --ignore-pattern .wrangler --ignore-pattern test-results --ignore-pattern playwright-report --ignore-pattern .node_modules.stalled",
    "test": "node scripts/run-lib-tests.mjs",
    "test:e2e": "npm exec -- playwright test",
    "test:e2e:smoke": "npm exec -- playwright test smoke.spec.ts sitemap.spec.ts navigation.spec.ts locale-autodetect.spec.ts --project=mobile-chrome",
    "test:e2e:ci": "npm exec -- playwright test",
    "test:e2e:static": "npm run build && npm run test:e2e:static-only",
    "test:e2e:static-only": "npm exec -- cross-env PLAYWRIGHT_SERVE_STATIC=1 playwright test --project=mobile-chrome",
    "test:e2e:install": "npm exec -- playwright install chromium webkit",
    "typecheck": "npm exec -- next typegen && node ./node_modules/typescript/bin/tsc --noEmit",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build",
    "learn:strapi-push": "npm exec -- tsx scripts/push-learn-to-strapi.ts",
    "generate:assets": "node scripts/generate-seo-assets.mjs",
    "lh:mobile": "npx --yes lighthouse http://127.0.0.1:3000/ --only-categories=performance,accessibility,best-practices,seo --preset=mobile --output=html --output-path=./lighthouse-home-mobile.html --quiet"
  },
  "dependencies": {
    "@fontsource/poppins": "^5.2.7",
    "@swc/helpers": "0.5.23",
    "firebase": "^12.16.0",
    "mixpanel-browser": "^2.81.0",
    "next": "^16.2.10",
    "posthog-js": "^1.404.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "engines": {
    "node": ">=26 <27"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@typescript/typescript6": "^6.0.2",
    "autoprefixer": "^10.5.4",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "firebase-tools": "^15.24.0",
    "globals": "^17.7.0",
    "postcss": "^8.5.19",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.111.0"
  },
  "overrides": {
    "postcss": "^8.5.19",
    "uuid": "^11.1.1"
  }
}
